# GitHub App Configuration
# Fill these in after registering your GitHub App

# Your GitHub App's ID (found on the app settings page)
APP_ID=

# Path to the .pem private key file downloaded when creating the app
PRIVATE_KEY_PATH=./private-key.pem

# Webhook secret configured on the app
WEBHOOK_SECRET=

# Port for the Express server
PORT=3000

# Smee.io webhook proxy URL (get one at https://smee.io/new)
SMEE_URL=
